realm=yourdomain.ru
server-name=yourdomain.ru

listening-port=3478
tls-listening-port=5349

fingerprint
lt-cred-mech
use-auth-secret
# Тот же секрет, что TURN_SHARED_SECRET в .env: openssl rand -hex 32
static-auth-secret=ВАШ_TURN_SECRET

# Диапазон UDP для медиа
min-port=49152
max-port=65535

log-file=stdout
no-multicast-peers
