# Скопируйте в livekit.yaml и подставьте ключи из .env.
# При network_mode: host в Docker порты слушаются на хосте напрямую.
#
# Внимание: если на сервере уже занят порт 7880/7881 другим livekit-инстансом,
# используйте другие порты (например 7884/7885) и другой UDP-диапазон.

port: 7884
bind_addresses:
  - "0.0.0.0"

rtc:
  tcp_port: 7885
  port_range_start: 50200
  port_range_end: 50300
  use_external_ip: true

# Замените на LIVEKIT_API_KEY: LIVEKIT_API_SECRET из .env
keys:
  your_api_key: your_api_secret
