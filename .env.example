# Скопируйте в .env и заполните (файл .env не коммитьте в git).
# Домен без схемы, как в Matrix server_name.
DOMAIN=yourdomain.ru
MATRIX_HOSTNAME=matrix.yourdomain.ru

# LiveKit API key/secret (сгенерируйте: см. README)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Homservers, которым lk-jwt выдаёт токены (через запятую при нескольких)
LIVEKIT_FULL_ACCESS_HOMESERVERS=yourdomain.ru

# Публичный WebSocket URL SFU (как видит клиент за HTTPS / Nginx)
LIVEKIT_URL=wss://matrix.yourdomain.ru/livekit/sfu

# Для coturn (docker-compose.coturn.yml): тот же секрет, что static-auth-secret в turnserver.conf
TURN_SHARED_SECRET=

# Каталог Let's Encrypt на хосте (в контейнер монтируется целиком; в turnserver.conf пути как в примере)
LETSENCRYPT_DIR=/etc/letsencrypt
