# Скопируйте в .env и заполните (файл .env не коммитьте в git).
DOMAIN=yourdomain.ru
MATRIX_HOSTNAME=matrix.yourdomain.ru

# LiveKit API key/secret — сгенерируйте: openssl rand -hex 12 / openssl rand -hex 32
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Homeservers, которым lk-jwt выдаёт токены
LIVEKIT_FULL_ACCESS_HOMESERVERS=yourdomain.ru

# Публичный WebSocket URL SFU (как видит клиент через Nginx)
LIVEKIT_URL=wss://matrix.yourdomain.ru/livekit/sfu

# Для coturn — тот же секрет, что static-auth-secret в turnserver.conf
TURN_SHARED_SECRET=
